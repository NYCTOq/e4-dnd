[
  {
    "id": "path-of-the-berserker",
    "name": "Path of the Berserker",
    "className": "Barbarian",
    "ruleset": "dnd_2014",
    "selectionLevel": 3,
    "description": "Rage sırasında saldırgan bonus-action baskısı, condition bağışıklığı, korkutma ve reaction saldırısı sağlayan 2014 Barbarian yolu.",
    "features": [
      {
        "level": 3,
        "name": "Frenzy",
        "summary": "Rage başlarken Frenzy seçilirse sonraki turlarda bonus action melee weapon attack açılır; Rage bitince exhaustion uygulanır."
      },
      {
        "level": 6,
        "name": "Mindless Rage",
        "summary": "Rage sırasında Charmed ve Frightened durumlarına bağışıklık; Rage başlarken mevcut durumları sonlandırır."
      },
      {
        "level": 10,
        "name": "Intimidating Presence",
        "summary": "Action ile Wisdom save isteyen frightened etkisi; sonraki turlarda action ile sürdürülebilir."
      },
      {
        "level": 14,
        "name": "Retaliation",
        "summary": "5 feet içindeki bir yaratık hasar verdiğinde reaction ile melee weapon attack."
      }
    ]
  },
