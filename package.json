{
  "name": "e4_dnd",
  "private": true,
  "version": "5.92.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint src",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm test && npm run build",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:mobile": "playwright test --project=mobile-chromium",
    "check:full": "npm run check && npm run test:e2e",
    "test:e2e:builder": "playwright test e2e/builder-ui-mega.spec.ts",
    "verify:builder": "npm run test -- builderUiNavigation && npm run build && npm run test:e2e:builder",
    "test:e2e:journey": "playwright test e2e/player-journey-integration.spec.ts",
    "verify:journey": "npm run test -- playerJourneyIntegration && npm run build && npm run test:e2e:journey",
    "test:e2e:content": "playwright test e2e/content-integrity-audit.spec.ts",
    "verify:content": "npm run test -- contentIntegrityAudit && npm run build && npm run test:e2e:content"
  },
  "dependencies": {
    "framer-motion": "^12.42.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  }
}
